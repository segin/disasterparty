# Disaster Party Environment Variables Example
# Copy this file to .env and fill in your keys for testing.

# --- OpenAI Compatible API ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-nano
OPENAI_MODEL_VISION=gpt-4o

# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEST_IMAGE_PATH=tests/assets/test_image_small.jpg

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-7-sonnet-20250219
ANTHROPIC_TEST_IMAGE_PATH=tests/assets/test_image_small.jpg

# --- General Test Settings ---
TEST_IMAGE_PATH_1=tests/assets/test_image_small.jpg
TEST_IMAGE_PATH_2=tests/assets/test_image_medium.png
DP_MOCK_SERVER=http://localhost:5000
TMPDIR=/tmp
